{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_HOME:-$HOME/.codex}/hooks/codex_hook.py\" SessionStart",
            "timeout": 5,
            "statusMessage": "loading platform guardrails"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_HOME:-$HOME/.codex}/hooks/codex_hook.py\" UserPromptSubmit",
            "timeout": 5,
            "statusMessage": "validating prompt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_HOME:-$HOME/.codex}/hooks/codex_hook.py\" PreToolUse",
            "timeout": 5,
            "statusMessage": "checking shell command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_HOME:-$HOME/.codex}/hooks/codex_hook.py\" PostToolUse",
            "timeout": 5,
            "statusMessage": "recording shell result"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_HOME:-$HOME/.codex}/hooks/codex_hook.py\" Stop",
            "timeout": 5,
            "statusMessage": "checking completion evidence"
          }
        ]
      }
    ]
  }
}
